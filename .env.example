# ---------------------------------------------------------------------------
# Noblie Bidding — environment variables
# Copy this file to `.env.local` and fill in real values.
# ---------------------------------------------------------------------------

# Public site URL, no trailing slash. Used for canonical URLs, sitemap, OG tags.
NEXT_PUBLIC_SITE_URL=https://nobliebidding.com

# Resend API key for transactional email (contact + quote forms).
# Get one at https://resend.com. If this is unset, forms still succeed in
# development and the payload is logged to the server console instead.
RESEND_API_KEY=

# Address that form submissions are delivered to.
CONTACT_TO_EMAIL=info@nobliebidding.com

# Verified "from" address on your Resend domain.
CONTACT_FROM_EMAIL=noreply@nobliebidding.com
